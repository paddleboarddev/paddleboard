#!/usr/bin/env bash

set -euxo pipefail

# PaddleBoard: ported from Zed's installer — paths, names, and app IDs.
if [[ $# -gt 0 ]]; then
  echo "
  Usage: ${0##*/}
  Builds and installs PaddleBoard onto your system into ~/.local, making it available as ~/.local/bin/paddleboard.

  Before running this you should ensure you have all the build dependencies installed with `./script/linux`.
  "
  exit 1
fi
export PADDLEBOARD_CHANNEL=$(<crates/paddleboard/RELEASE_CHANNEL)
export PADDLEBOARD_UPDATE_EXPLANATION="You need to fetch and rebuild PaddleBoard in $(pwd)"
script/bundle-linux

arch="$(uname -m)"
commit=$(git rev-parse HEAD | cut -c 1-7)
archive="paddleboard-linux-${arch}.tar.gz"
export PADDLEBOARD_BUNDLE_PATH="${CARGO_TARGET_DIR:-target}/release/${archive}"
script/install.sh
