#!/usr/bin/env bash
#
# script/check-upstream-drift
#
# Reports how far PaddleBoard's upstream-shaped crates have drifted from
# zed-industries/zed:main. The metric is `git diff --shortstat` per
# crate, plus a count of `// PaddleBoard:` divergence markers — the
# tagged surface that should resolve mechanically during weekly merges.
#
# A growing diff number tells you either (a) you're diverging more or
# (b) the last upstream merge is getting stale. Both are signals to
# act before the next merge gets quadratically expensive.
#
# Runs on every PR (results post as a sticky comment) and weekly via
# `.github/workflows/upstream-drift.yml`. Also runnable locally:
#
#   ./script/check-upstream-drift                  # writes markdown to stdout
#   ./script/check-upstream-drift --no-fetch        # skip the `git fetch`
#   UPSTREAM_REF=zed/main ./script/check-upstream-drift

set -euo pipefail

UPSTREAM_REMOTE="${UPSTREAM_REMOTE:-zed}"
UPSTREAM_REPO="${UPSTREAM_REPO:-https://github.com/zed-industries/zed.git}"
UPSTREAM_REF="${UPSTREAM_REF:-${UPSTREAM_REMOTE}/main}"

DO_FETCH=1
for arg in "$@"; do
    case "$arg" in
        --no-fetch) DO_FETCH=0 ;;
        -h|--help)
            sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'
            exit 0
            ;;
    esac
done

# Crates that exist in both PaddleBoard and zed-industries/zed and that
# we want to track drift on. Excludes:
#   - `paddleboard_*` (net-new in our fork; no upstream baseline)
#   - `grammars/` (we own this dir's layout for the language bake-ins)
#   - smaller-blast-radius crates (theme, file_icons, etc.) — add later
#     if a specific incident motivates it
CORE_CRATES=(
    agent
    agent_ui
    buffer_diff
    client
    collab
    collab_ui
    editor
    gpui
    language
    language_core
    lsp
    multi_buffer
    project
    rope
    settings_content
    text
    workspace
)

# Ensure the upstream remote exists.
if ! git remote get-url "$UPSTREAM_REMOTE" >/dev/null 2>&1; then
    git remote add "$UPSTREAM_REMOTE" "$UPSTREAM_REPO"
fi

if [ "$DO_FETCH" = 1 ]; then
    git fetch --quiet "$UPSTREAM_REMOTE" main --no-tags
fi

upstream_short=$(git rev-parse --short "$UPSTREAM_REF")
head_short=$(git rev-parse --short HEAD)
merge_base=$(git merge-base HEAD "$UPSTREAM_REF" 2>/dev/null || echo "unknown")
merge_base_short=$(git rev-parse --short "$merge_base" 2>/dev/null || echo "unknown")

# Extract one number from a `--shortstat` line. Patterns look like:
#   "  17 files changed, 246 insertions(+), 91 deletions(-)"
shortstat_num() {
    local stat="$1" pattern="$2"
    local out
    out=$(printf '%s' "$stat" | grep -oE "[0-9]+ $pattern" | head -1 | grep -oE "[0-9]+" || true)
    printf '%s' "${out:-0}"
}

cat <<EOF
# Upstream drift report

Comparing PaddleBoard \`HEAD\` (\`$head_short\`) against \`zed-industries/zed:main\` (\`$upstream_short\`).
Last common ancestor: \`$merge_base_short\`.

| Crate | Files | Insertions | Deletions | \`// PaddleBoard:\` tags |
|-------|-------|------------|-----------|------------------------|
EOF

total_files=0
total_ins=0
total_del=0
total_tags=0

for crate in "${CORE_CRATES[@]}"; do
    path="crates/$crate"
    if [ ! -d "$path" ]; then
        printf "| \`%s\` | _(missing locally)_ | — | — | — |\n" "$path"
        continue
    fi

    stat=$(git diff --shortstat "$UPSTREAM_REF" -- "$path" 2>/dev/null || echo "")
    files=$(shortstat_num "$stat" "files? changed")
    ins=$(shortstat_num "$stat" "insertions?")
    del=$(shortstat_num "$stat" "deletions?")

    # `git grep -c` exits 1 when nothing matches, which `set -o pipefail`
    # would normally turn into a script failure — disable pipefail for
    # the duration of this pipeline so an empty match counts as zero
    # rather than aborting.
    tags=$({ set +o pipefail; git grep -I -c "// PaddleBoard:" -- "$path" 2>/dev/null \
        | awk -F: 'BEGIN{s=0} {s += $NF} END {print s}'; })
    tags=${tags:-0}

    total_files=$((total_files + files))
    total_ins=$((total_ins + ins))
    total_del=$((total_del + del))
    total_tags=$((total_tags + tags))

    printf "| \`crates/%s\` | %s | +%s | -%s | %s |\n" \
        "$crate" "$files" "$ins" "$del" "$tags"
done

printf "| **Total** | **%s** | **+%s** | **-%s** | **%s** |\n" \
    "$total_files" "$total_ins" "$total_del" "$total_tags"

echo
echo "_Generated by \`script/check-upstream-drift\`. See \`FORK_HYGIENE.md\` for context._"
